# Auto-detect text files and normalize line endings
* text=auto

# Force LF for code files
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.env text eol=lf
*.svg text eol=lf

# Force CRLF for Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (no diff, no merge, no convert)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.wasm binary
*.bin binary
*.zip binary

# Git LFS for large model files
server/models/*.bin filter=lfs diff=lfs merge=lfs -text
server/models/*-shard* filter=lfs diff=lfs merge=lfs -text

# Tesseract data
*.traineddata filter=lfs diff=lfs merge=lfs -text
