NODE_ENV=dev
PORT=8105

# Database
POSTGRES_DB=vultid
POSTGRES_USER=vultid
POSTGRES_PASSWORD=cambiar_en_produccion
DB_PORT=5432
DATABASE_URL=postgresql://vultid:cambiar_en_produccion@db:5432/vultid

# API Port
API_PORT=8105

# Dashboard Port
DASHBOARD_PORT=8080

# CORS
FACEAPI_ORIGIN_ALLOWED=*

# Endpoints
DEMOGNITION_ENDPOINT=/login-user-test/
RECOGNITION_ENDPOINT=/recognize/
VERIFICATION_ENDPOINT=/verify-id/

# JWT (cambiar en produccion)
JWT_SECRET=tu_jwt_secret_aqui
JWT_EXPIRES_IN=15m

# Admin Auth (cambiar en produccion)
ADMIN_USER=admin
ADMIN_PASS=cambiar_en_produccion

# App
APP_URL=http://localhost:3000
APP_NAME=VULT ID

# Wompi El Salvador
WOMPI_APP_ID=tu_app_id
WOMPI_API_SECRET=tu_api_secret
WOMPI_API_URL=https://api.wompi.sv
WOMPI_AUTH_URL=https://id.wompi.sv/connect/token

# Email (ZOHO)
ZOHO_API_KEY=tu_zoho_api_key
ZOHO_FROM_EMAIL=noreply@tudominio.com
ZOHO_FROM_NAME=VULT ID
